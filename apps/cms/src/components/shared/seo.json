{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO",
    "description": "Basic SEO and Open Graph fields for marketing pages"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true
    },
    "metaDescription": {
      "type": "text",
      "required": true
    },
    "canonicalURL": {
      "type": "string"
    },
    "ogTitle": {
      "type": "string"
    },
    "ogDescription": {
      "type": "text"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "noIndex": {
      "type": "boolean",
      "default": false
    }
  }
}
