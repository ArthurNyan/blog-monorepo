{
  "name": "front",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/front",
  "sourceRoot": "apps/front/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm dev",
        "cwd": "apps/front"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm build",
        "cwd": "apps/front"
      },
      "outputs": ["{projectRoot}/dist", "{projectRoot}/.astro"]
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm preview",
        "cwd": "apps/front"
      }
    },
    "generate:api": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm generate:api",
        "cwd": "apps/front"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No lint configured for front yet'",
        "cwd": "apps/front"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No tests configured for front yet'",
        "cwd": "apps/front"
      }
    }
  }
}
