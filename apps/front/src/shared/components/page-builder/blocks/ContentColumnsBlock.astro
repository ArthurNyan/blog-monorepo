---
import type { ContentColumnsBlock as ContentColumnsBlockType } from "@/shared/api/pages";
import { MarkdownContent } from "@/shared/components/MarkdownContent";

interface Props {
	block: ContentColumnsBlockType;
}

const { block } = Astro.props as Props;

if (!block.columns?.length) {
	return;
}
---

<section class="py-16 md:py-20">
	<div class="container mx-auto px-4">
		<div class="mx-auto max-w-6xl">
			{block.eyebrow && (
				<p class="mb-3 text-sm uppercase tracking-[0.24em] text-muted-foreground">
					{block.eyebrow}
				</p>
			)}
			{block.heading && (
				<h2 class="max-w-3xl text-3xl font-semibold tracking-tight md:text-5xl">
					{block.heading}
				</h2>
			)}
			<div class="mt-10 grid gap-8 md:grid-cols-2">
				{block.columns.map((column) => (
					<div class="rounded-2xl border border-border/70 bg-background/60 p-6 md:p-8">
						<h3 class="mb-5 text-2xl font-semibold">{column.title}</h3>
						<MarkdownContent content={column.body} />
					</div>
				))}
			</div>
		</div>
	</div>
</section>
