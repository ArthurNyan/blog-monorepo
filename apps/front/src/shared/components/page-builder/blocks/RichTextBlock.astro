---
import type { RichTextBlock as RichTextBlockType } from "@/shared/api/pages";
import { MarkdownContent } from "@/shared/components/MarkdownContent";

interface Props {
	block: RichTextBlockType;
}

const { block } = Astro.props as Props;
---

<section class="py-16 md:py-20">
	<div class="container mx-auto px-4">
		<div class="mx-auto max-w-4xl">
			{block.heading && (
				<h2 class="mb-8 text-3xl font-semibold tracking-tight md:text-5xl">
					{block.heading}
				</h2>
			)}
			<MarkdownContent content={block.body} />
		</div>
	</div>
</section>
