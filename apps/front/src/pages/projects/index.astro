---
import MainLayout from "@/layouts/main.astro";
import { getProjects } from "@/shared/api/generated";
import { ProjectCard } from "@/widgets/ProjectCard";
import { EmptyState } from "@/shared/components/EmptyState";

const { data: projects } = await getProjects({ query: { populate: "*" } });
---

<MainLayout content={{ title: "Проекты" }} className="flex flex-col">
	<div class="container mx-auto px-4 py-12 md:py-16">
		<div class="mb-8 md:mb-12">
			<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 md:mb-4">
				Проекты
			</h1>
			<p class="text-base md:text-lg text-muted-foreground">
				Портфолио выполненных проектов и разработок
			</p>
		</div>

		{
			projects?.data && projects.data.length > 0 ? (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
					{projects.data.map((project) => (
						<ProjectCard project={project} client:load />
					))}
				</div>
			) : (
				<EmptyState
					title="Проекты пока не опубликованы"
					description="Следите за обновлениями, скоро здесь появятся новые проекты"
					client:load
				/>
			)
		}
	</div>
</MainLayout>
