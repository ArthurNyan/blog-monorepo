---
import MainLayout from "@/layouts/main.astro";
import { fetchArticleBySlug } from "@/shared/api/pages";
import { DetailHero } from "@/shared/components/DetailHero";
import { MarkdownContent } from "@/shared/components/MarkdownContent";
import {
	buildPublicCollectionPath,
	getPreviewCmsRequestOptions,
	hasValidPreviewCookie,
} from "@/shared/preview/session";
import { buildSeoMetadata } from "@/shared/seo/metadata";
import { isSiteLocale, toCmsLocale } from "@/shared/i18n/config";

export const prerender = false;

const locale = Astro.params.locale;
const { slug } = Astro.params;

if (!isSiteLocale(locale)) {
	return Astro.redirect(buildPublicCollectionPath("article"));
}

if (!slug) {
	return new Response("Preview article slug is required.", { status: 400 });
}

if (!hasValidPreviewCookie(Astro.cookies)) {
	return Astro.redirect(buildPublicCollectionPath("article", slug));
}

const pathname = buildPublicCollectionPath("article", slug);
const article = await fetchArticleBySlug(
	slug,
	toCmsLocale(locale),
	getPreviewCmsRequestOptions()
);

if (!article) {
	return new Response("Preview article not found.", { status: 404 });
}

const seo = buildSeoMetadata({
	title: article.name,
	description: article.description,
	pathname,
	noIndex: true,
	status: "draft",
});
---

<MainLayout
	content={{
		title: article.name,
		description: article.description,
		seo,
		pathname,
		locale,
		lang: locale,
		previewMode: true,
		cmsStatus: "draft",
	}}
	className="flex flex-col"
>
	<DetailHero
		title={article.name}
		description={article.description}
		date={article.date}
		cover={article.cover || undefined}
		authors={article.authors}
	/>
	{
		article.content && (
			<article class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 md:py-16 lg:py-20">
				<div class="max-w-4xl mx-auto">
					<MarkdownContent content={article.content} />
				</div>
			</article>
		)
	}
</MainLayout>
