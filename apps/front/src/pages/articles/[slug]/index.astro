---
import MainLayout from "@/layouts/main.astro";
import { getArticles } from "@/shared/api/generated";
import { fetchArticleBySlug } from "@/shared/api/pages";
import { DetailHero } from "@/shared/components/DetailHero";
import { MarkdownContent } from "@/shared/components/MarkdownContent";

export const getStaticPaths = async () => {
    const response = await getArticles();
    if (!response.data) {
        return [];
    }
    return response.data.data?.map((article) => ({
        params: { slug: article.slug },
    }));
};

const slug = Astro.params.slug as string;
const articleData = await fetchArticleBySlug(slug);

if (!articleData) {
	return new Response("Article not found.", { status: 404 });
}
---

<MainLayout
    content={{ title: articleData?.name || "Статья" }}
    className="flex flex-col"
>
	<>
		<DetailHero
			title={articleData.name}
			description={articleData.description}
			date={articleData.date}
			cover={articleData.cover || undefined}
			authors={articleData.authors}
		/>
		<article class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 md:py-16 lg:py-20">
			<div class="max-w-4xl mx-auto">
				{articleData.content && <MarkdownContent content={articleData.content} />}
			</div>
		</article>
	</>
</MainLayout>
