---
import MainLayout from "@/layouts/main.astro";
import { getArticles, getArticlesId } from "@/shared/api/generated";
import { DetailHero, createArticleHeroProps } from "@/shared/components/DetailHero";
import { MarkdownContent } from "@/shared/components/MarkdownContent";

export const getStaticPaths = async () => {
    const response = await getArticles();
    if (!response.data) {
        return [];
    }
    return response.data.data?.map((article) => ({
        params: { slug: article.slug },
        props: {
            documentId: article.documentId,
        },
    }));
};

const { documentId } = Astro.props;
const { data: article } = await getArticlesId({
    path: {
        id: documentId as unknown as number,
    },
});

const articleData = article?.data;
---

<MainLayout
    content={{ title: articleData?.name || "Статья" }}
    className="flex flex-col"
>
    {
        articleData && (
            <>
                <DetailHero {...createArticleHeroProps(articleData)} />
                <article class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 md:py-16 lg:py-20">
                    <div class="max-w-4xl mx-auto">
                        {articleData.content && (
                            <MarkdownContent content={articleData.content} />
                        )}
                    </div>
                </article>
            </>
        )
    }
</MainLayout>
