---
import "@/shared/styles/__global.css";
import stylesUrl from "@/shared/styles/__global.css?url";
import { Header } from "@/widgets/Header";
import { Footer } from "@/widgets/Footer";
import { cn } from "@/shared/lib/utils";

const { content, className } = Astro.props;
const title = content?.seo?.metaTitle || content?.title || "Untitled page";
const description = content?.seo?.metaDescription || content?.description;
const canonicalURL = content?.seo?.canonicalURL;
const ogTitle = content?.seo?.ogTitle || title;
const ogDescription = content?.seo?.ogDescription || description;
const ogImageUrl = content?.seo?.ogImageUrl;
const noIndex = content?.seo?.noIndex;
const lang = content?.lang || "en";
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preload" href={stylesUrl} as="style" />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonicalURL && <link rel="canonical" href={canonicalURL} />}
		<meta property="og:title" content={ogTitle} />
		{ogDescription && <meta property="og:description" content={ogDescription} />}
		<meta property="og:type" content="website" />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{noIndex && <meta name="robots" content="noindex, nofollow" />}
	</head>
	<body class="dark">
		<div class={"w-full min-h-screen"}>
			<Header client:load />
			<main class={cn("w-full", className)}>
				<slot />
			</main>
			<Footer client:visible />
		</div>
	</body>
</html>
