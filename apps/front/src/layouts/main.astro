---
import "@/shared/styles/__global.css";
import stylesUrl from "@/shared/styles/__global.css?url";
import { fetchGlobalContent } from "@/shared/api/site";
import { buildLocalizedPath, toHtmlLang, toSiteLocale } from "@/shared/i18n/config";
import { Header } from "@/widgets/Header";
import { Footer } from "@/widgets/Footer";
import { cn } from "@/shared/lib/utils";

const { content, className } = Astro.props;
const title = content?.seo?.metaTitle || content?.title || "Untitled page";
const description = content?.seo?.metaDescription || content?.description;
const canonicalURL = content?.seo?.canonicalURL;
const ogTitle = content?.seo?.ogTitle || title;
const ogDescription = content?.seo?.ogDescription || description;
const ogImageUrl = content?.seo?.ogImageUrl;
const noIndex = content?.seo?.noIndex;
const siteLocale = toSiteLocale(content?.locale || content?.lang);
const lang = toHtmlLang(content?.locale || content?.lang);

let globalContent = undefined;

try {
	globalContent = await fetchGlobalContent(siteLocale);
} catch (error) {
	console.warn("Failed to load global content from CMS.", error);
}

const headerBrand = globalContent
	? {
			title: globalContent.companyName,
			href: globalContent.homeHref || buildLocalizedPath(siteLocale),
		}
	: undefined;

const footerCompanyInfo = globalContent
	? {
			name: globalContent.companyName,
			description: globalContent.description,
			logoDark: globalContent.logoUrl || "/logo_dark.png",
			logoLight: globalContent.logoUrl || "/logo_light.png",
		}
	: undefined;
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preload" href={stylesUrl} as="style" />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonicalURL && <link rel="canonical" href={canonicalURL} />}
		<meta property="og:title" content={ogTitle} />
		{ogDescription && <meta property="og:description" content={ogDescription} />}
		<meta property="og:type" content="website" />
		{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
		{noIndex && <meta name="robots" content="noindex, nofollow" />}
	</head>
	<body class="dark">
		<div class={"w-full min-h-screen"}>
			<Header
				client:load
				navigationItems={
					globalContent?.navigationItems.length
						? globalContent.navigationItems
						: undefined
				}
				brand={headerBrand}
				primaryAction={globalContent?.headerPrimaryCta}
				secondaryAction={globalContent?.headerSecondaryCta}
			/>
			<main class={cn("w-full", className)}>
				<slot />
			</main>
			<Footer
				client:visible
				columns={
					globalContent?.footerColumns.length
						? globalContent.footerColumns
						: undefined
				}
				companyInfo={footerCompanyInfo}
				copyrightText={globalContent?.footerCopyright}
			/>
		</div>
	</body>
</html>
